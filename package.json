{
  "name": "@scanton/phase2s",
  "version": "1.44.0",
  "description": "AI coding assistant with 29 built-in skills, ChatGPT subscription support, and autonomous spec execution",
  "author": "Scott Canton",
  "homepage": "https://github.com/scanton/phase-2-s",
  "repository": {
    "type": "git",
    "url": "https://github.com/scanton/phase-2-s.git"
  },
  "bugs": {
    "url": "https://github.com/scanton/phase-2-s/issues"
  },
  "type": "module",
  "files": [
    "dist/",
    "!dist/action/",
    ".phase2s/",
    "README.md",
    "LICENSE"
  ],
  "main": "dist/cli/index.js",
  "bin": {
    "phase2s": "dist/bin/phase2s.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/bin/phase2s.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:action": "ncc build src/action/index.ts -o dist/action --license licenses.txt"
  },
  "test": {
    "include": [
      "test/**/*.test.ts"
    ],
    "environment": "node"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "ai",
    "codex",
    "openai",
    "anthropic",
    "claude",
    "chatgpt",
    "cli",
    "agent",
    "mcp",
    "coding-assistant",
    "dark-factory"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@iarna/toml": "^2.2.5",
    "@mozilla/readability": "^0.6.0",
    "@types/iarna__toml": "^2.0.5",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "glob": "^13.0.0",
    "linkedom": "^0.18.12",
    "marked": "^18.0.2",
    "openai": "^4.73.0",
    "yaml": "^2.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@actions/core": "^3.0.0",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^9.0.0",
    "@types/node": "^22.9.0",
    "@vercel/ncc": "^0.38.4",
    "playwright": ">=1.40.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "playwright": ">=1.40.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "overrides": {
    "formdata-node": "^6.0.0"
  }
}
