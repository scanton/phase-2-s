{
  "name": "@scanton/phase2s",
  "version": "0.22.0",
  "description": "AI programming harness with multi-model support",
  "type": "module",
  "files": [
    "dist/",
    ".phase2s/",
    "README.md",
    "LICENSE"
  ],
  "main": "dist/cli/index.js",
  "bin": {
    "phase2s": "dist/bin/phase2s.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/bin/phase2s.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "test": {
    "include": [
      "test/**/*.test.ts"
    ],
    "environment": "node"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "ai",
    "codex",
    "openai",
    "cli",
    "agent"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@iarna/toml": "^2.2.5",
    "@types/iarna__toml": "^2.0.5",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "glob": "^13.0.0",
    "openai": "^4.73.0",
    "yaml": "^2.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "formdata-node": "^6.0.0"
  }
}
